rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // Public Content: Allow anyone to read these collections.
    match /news/{document=**} { allow read: if true; }
    match /banners/{document=**} { allow read: if true; }
    match /categories/{document=**} { allow read: if true; }
    match /countries/{document=**} { allow read: if true; }
    match /businesses/{document=**} { allow read: if true; }
    match /restaurants/{document=**} { allow read: if true; }
    match /events/{document=**} { allow read: if true; }
    match /jobs/{document=**} { allow read: if true; }
    match /legal/{document=**} { allow read: if true; }
    match /support/{document=**} { allow read: if true; }
    match /notifications/{document=**} { allow read: if true; }

    // Users: Only the owner can read or write their own profile data.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Email Queue: 
    // CRITICAL for Forgot Password: Allow ANYONE to create a document.
    // Deny read/update/delete to prevent users from seeing other emails.
    match /email_queue/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}